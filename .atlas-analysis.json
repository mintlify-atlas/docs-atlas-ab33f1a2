  "keyFeatures": [
    "Type-safe TypeScript SDK for the complete Cloudflare API",
    "Auto-pagination for list methods with async iterators",
    "Automatic retries with exponential backoff",
    "Support for multiple authentication methods",
    "File upload capabilities for Workers, Images, and Stream",
    "Comprehensive error handling with typed exceptions",
    "Multi-runtime support (Node.js, Deno, Bun, Cloudflare Workers)",
    "Built-in request/response middleware"
